/*
 * secrets.h - Configuration for DiashowDL Sensor Node.
 *
 * Instructions:
 * 1. Copy this file to tools/sensor/esp32/secrets.h
 * 2. Enter your real credentials below.
 */

#ifndef SECRETS_H
#define SECRETS_H

// WiFi Configuration
const char* WIFI_SSID = "YOUR_WIFI_SSID";
const char* WIFI_PASS = "YOUR_WIFI_PASSWORD";

// Sensor API Key — clients must send this in the X-Api-Key header
const char* API_KEY = "your-sensor-api-key";  // At least 8 characters

// Host name for this sensor node (shown in the Diashow App scan list)
const char* HOSTNAME = "ESP32";

// SSL Certificate and Private Key (PEM format)
// Run ./generate_cert.sh to generate and insert these automatically.
static const char SERVER_CERT[] = "PASTE_CERT_PEM_HERE";
static const char SERVER_KEY[]  = "PASTE_KEY_PEM_HERE";

#endif
