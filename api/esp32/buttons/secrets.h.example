/*
 * secrets.h - Configuration for DiashowDL ESP32 Button Control.
 * 
 * Instructions:
 * 1. Copy this file to tools/api/esp32/buttons/secrets.h
 * 2. Enter your real credentials below.
 */

#ifndef SECRETS_H
#define SECRETS_H

// WiFi Configuration
const char* WIFI_SSID = "YOUR_WIFI_SSID";
const char* WIFI_PASS = "YOUR_WIFI_PASSWORD";

// DiashowDL API Configuration
const char* DIASHOW_IP  = "192.168.1.100";  // The Display Server IP
const int   DIASHOW_PORT = 9134;            // Standard port is 9134 (HTTPS)
const char* DIASHOW_KEY  = "your-api-key";  // At least 8 characters

#endif
